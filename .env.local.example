# ─────────────────────────────────────────────────────────────────────────
# Bossman environment variables
#
# HOW TO USE:
#   1. Copy this file to ".env.local"   (that file is git-ignored — safe)
#   2. Paste your real key after the "=" below
#   3. Restart the app (npm run dev)
#
# With no key set, Bossman runs on its built-in heuristic (still works!).
# With the key set, the planner and onboarding think with real Claude.
# ─────────────────────────────────────────────────────────────────────────

# Your Anthropic (Claude) API key — starts with "sk-ant-..."
ANTHROPIC_API_KEY=

# Optional: which Claude model Bossman uses for its own planning.
# Leave as-is unless you know you want a different one.
BOSSMAN_PLANNER_MODEL=claude-opus-4-8
